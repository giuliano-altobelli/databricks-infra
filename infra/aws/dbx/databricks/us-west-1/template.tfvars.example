# =============================================================================
# Generic tfvars Reference (Historical Example)
# =============================================================================
# Reference only. The sandbox branch is validated only with scenario2.sandbox-create-managed.tfvars.

# -----------------------------------------------------------------------------
# Required Core Variables
# -----------------------------------------------------------------------------
aws_account_id         = "441735166692"
region                 = "us-west-2"
admin_user             = "giulianoaltobelli@gmail.com"
databricks_account_id  = "535f803e-200e-4ff7-985a-7673a0f53375"
resource_prefix        = "personal-infra"

# -----------------------------------------------------------------------------
# Workspace Selection (reference: existing workspace)
# -----------------------------------------------------------------------------
pricing_tier           = "PREMIUM"
workspace_source       = "existing"
existing_workspace_host = "https://dbc-9edb2ce7-da55.cloud.databricks.com"
existing_workspace_id   = "7474651824071073"

# -----------------------------------------------------------------------------
# Network Configuration
# -----------------------------------------------------------------------------
# managed  = Databricks-managed networking
# isolated = Customer-managed isolated networking
# custom   = Reuse existing customer networking assets
network_configuration = "managed"

# For reference, this example uses an existing metastore.
metastore_exists = true

# Required only when metastore_exists = false.
# Example: metastore_storage_root = "s3://<bucket>/<path>"
# metastore_storage_root = null

# -----------------------------------------------------------------------------
# Trial-Safe Feature Flags
# -----------------------------------------------------------------------------
enable_audit_log_delivery      = false
audit_log_delivery_exists      = false
enable_example_cluster         = false
enable_security_analysis_tool  = false

# Optional compliance settings
enable_compliance_security_profile = false
compliance_standards               = ["Standard_A", "Standard_B"]

# Optional Databricks settings
deployment_name      = null
databricks_gov_shard = null

# -----------------------------------------------------------------------------
# Create Workspace Later (optional)
# -----------------------------------------------------------------------------
# Switch to this when you are ready to have Terraform create a workspace.
# workspace_source        = "create"
# existing_workspace_host = null
# existing_workspace_id   = null
# network_configuration   = "managed"

# -----------------------------------------------------------------------------
# Upgrade to Enterprise SRA (optional)
# -----------------------------------------------------------------------------
# pricing_tier         = "ENTERPRISE"
# workspace_source     = "create"
# network_configuration = "isolated"
# enable_audit_log_delivery = true

# Isolated network inputs (required when network_configuration = "isolated")
# vpc_cidr_range           = "10.0.0.0/18"
# private_subnets_cidr     = ["10.0.0.0/22", "10.0.4.0/22", "10.0.8.0/22"]
# privatelink_subnets_cidr = ["10.0.28.0/26", "10.0.28.64/26", "10.0.28.128/26"]
# sg_egress_ports          = ["443", "2443", "5432", "6666", "8443", "8444", "8445", "8446", "8447", "8448", "8449", "8450", "8451"]

# Custom network inputs (required when network_configuration = "custom")
# custom_vpc_id             = ""
# custom_private_subnet_ids = ["", ""]
# custom_sg_id              = ""
# custom_relay_vpce_id      = ""
# custom_workspace_vpce_id  = ""

# Optional CMK admin ARN (used in Enterprise CMK workflows)
# cmk_admin_arn = ""
